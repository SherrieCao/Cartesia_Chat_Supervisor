# Copy to .env and fill in. The SDK auto-loads .env locally (python-dotenv).
# For a deployed agent, set these on the platform instead:
#   cartesia env set --from .env

# Anthropic — primary provider (Claude Haiku/Opus) for both tiers
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Together AI — required for the Qwen/DeepSeek fallbacks (LiteLLM together_ai/ prefix)
TOGETHERAI_API_KEY=your-together-api-key-here

# Cartesia platform API key (sk_car_...). Only needed to run upload_knowledge.py,
# which populates the hosted knowledge base. Not used by the agent at runtime.
CARTESIA_API_KEY=sk_car_...

